{
  "info": {
    "name": "Eduardo Faustos System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"newuser@example.com\",\"name\":\"New User\",\"password\":\"Password123!\"}"
            },
            "url": {
              "raw": "{{auth_base_url}}/auth/register",
              "host": ["auth"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('jwt_token', jsonData.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"test@example.com\",\"password\":\"password123\"}"
            },
            "url": {
              "raw": "{{auth_base_url}}/auth/login",
              "host": ["auth"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{auth_base_url}}/auth/verify",
              "host": ["auth"],
              "path": ["api", "auth", "verify"]
            }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Get All Customers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orders_base_url}}/customers",
              "host": ["orders"],
              "path": ["api", "customers"]
            }
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Acme Corp\",\"email\":\"acme@example.com\",\"phone\":\"555-1234\",\"address\":\"123 Main St\",\"city\":\"New York\",\"state\":\"NY\",\"zip_code\":\"10001\"}"
            },
            "url": {
              "raw": "{{orders_base_url}}/customers",
              "host": ["orders"],
              "path": ["api", "customers"]
            }
          }
        },
        {
          "name": "Get Customer",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orders_base_url}}/customers/{{customer_id}}",
              "host": ["orders"],
              "path": ["api", "customers", "{{customer_id}}"]
            }
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Acme Corporation Updated\"}"
            },
            "url": {
              "raw": "{{orders_base_url}}/customers/{{customer_id}}",
              "host": ["orders"],
              "path": ["api", "customers", "{{customer_id}}"]
            }
          }
        },
        {
          "name": "Delete Customer",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{orders_base_url}}/customers/{{customer_id}}",
              "host": ["orders"],
              "path": ["api", "customers", "{{customer_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orders_base_url}}/orders?status=pending",
              "host": ["orders"],
              "path": ["api", "orders"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            }
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"customer_id\":1,\"items\":[{\"product_name\":\"Widget A\",\"quantity\":5,\"unit_price\":100},{\"product_name\":\"Widget B\",\"quantity\":3,\"unit_price\":200}]}"
            },
            "url": {
              "raw": "{{orders_base_url}}/orders",
              "host": ["orders"],
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orders_base_url}}/orders/{{order_id}}",
              "host": ["orders"],
              "path": ["api", "orders", "{{order_id}}"]
            }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\":\"completed\"}"
            },
            "url": {
              "raw": "{{orders_base_url}}/orders/{{order_id}}/status",
              "host": ["orders"],
              "path": ["api", "orders", "{{order_id}}", "status"]
            }
          }
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{orders_base_url}}/orders/{{order_id}}",
              "host": ["orders"],
              "path": ["api", "orders", "{{order_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orders_base_url}}/dashboard/stats",
              "host": ["orders"],
              "path": ["api", "dashboard", "stats"]
            }
          }
        },
        {
          "name": "Get Order Activity",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orders_base_url}}/dashboard/order-activity",
              "host": ["orders"],
              "path": ["api", "dashboard", "order-activity"]
            }
          }
        },
        {
          "name": "Get Revenue",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orders_base_url}}/dashboard/revenue",
              "host": ["orders"],
              "path": ["api", "dashboard", "revenue"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "auth_base_url",
      "value": "http://localhost:5005/api",
      "type": "string"
    },
    {
      "key": "orders_base_url",
      "value": "http://localhost:8001/api",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "customer_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "order_id",
      "value": "1",
      "type": "string"
    }
  ]
}
